# ============================================================
# GrowthPilot-Agent 环境变量示例文件
# ============================================================
#
# 使用方法：
#
# 1. 在项目根目录复制本文件：
#
#    Windows PowerShell:
#    copy .env.example .env
#
#    macOS / Linux:
#    cp .env.example .env
#
# 2. 打开 .env 文件，填入你自己的 DashScope API Key。
#
# 3. 注意：
#    .env 文件包含真实密钥，不要上传到 GitHub。
#    .env.example 只放示例配置，可以上传到 GitHub。
#
# ============================================================


# DashScope API Key
DASHSCOPE_API_KEY=your_dashscope_api_key_here


# DashScope OpenAI 兼容模式 Base URL
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1


# Qwen 模型名称
QWEN_MODEL=qwen-plus


# 生成随机性
QWEN_TEMPERATURE=0.7


# Embedding 配置
# hash：默认本地哈希 embedding，不依赖外部服务，适合稳定评测
# dashscope：使用 DashScope Embedding，失败时自动 fallback 到 hash
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=64