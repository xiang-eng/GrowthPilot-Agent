
# ============================================================
# GrowthPilot-Agent 环境变量示例文件
# ============================================================
#
# 使用方法：
#
# 1. 在项目根目录复制本文件：
#
#    Windows PowerShell:
#    copy .env.example .env
#
#    macOS / Linux:
#    cp .env.example .env
#
# 2. 打开 .env 文件，填入你自己的 DashScope API Key。
#
# 3. 注意：
#    .env 文件包含真实密钥，不要上传到 GitHub。
#    .env.example 只放示例配置，可以上传到 GitHub。
#
# ============================================================


# DashScope API Key
# 必填。用于调用通义千问大模型。
DASHSCOPE_API_KEY="sk-9569be7de0f349f79d2e8077630e0843"


# DashScope OpenAI 兼容模式 Base URL
# 一般不需要修改。
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1


# Qwen 模型名称
# 常用示例：
# QWEN_MODEL=qwen-plus
# QWEN_MODEL=qwen-turbo
QWEN_MODEL=qwen-plus


# 生成随机性
# 数值越低越稳定，数值越高越发散。
# 推荐范围：0.2 - 1.0
QWEN_TEMPERATURE=0.7