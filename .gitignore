# ============================================================
# GrowthPilot-Agent .gitignore
# ============================================================


# ============================================================
# 1. Environment variables and secrets
# ============================================================

.env
.env.*
!.env.example

*.key
*.pem
*.crt


# ============================================================
# 2. Python cache and bytecode
# ============================================================

__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd


# ============================================================
# 3. Virtual environments
# ============================================================

.venv/
venv/
env/
ENV/
agenttt/


# ============================================================
# 4. Python build artifacts
# ============================================================

build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/


# ============================================================
# 5. Test, lint and type-check caches
# ============================================================

.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.pyre/
.cache/


# ============================================================
# 6. Streamlit local files
# ============================================================

.streamlit/secrets.toml
.streamlit/cache/


# ============================================================
# 7. Project runtime outputs
# ============================================================

outputs/
vector_db/
*.log


# ============================================================
# 8. Local dependency freeze files
# ============================================================

requirements_freeze.txt
pip-freeze.txt


# ============================================================
# 9. Jupyter Notebook checkpoints
# ============================================================

.ipynb_checkpoints/


# ============================================================
# 10. IDE and editor files
# ============================================================

.vscode/
.idea/
*.swp
*.swo


# ============================================================
# 11. OS generated files
# ============================================================

.DS_Store
Thumbs.db
desktop.ini


# ============================================================
# 12. Temporary files
# ============================================================

tmp/
temp/
*.tmp
*.bak
*.old