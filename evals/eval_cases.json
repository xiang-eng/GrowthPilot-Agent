{
  "required_data_columns": {
    "product": ["product_id", "product_name", "category", "price"],
    "sales": ["product_id", "views", "clicks", "orders", "refunds"],
    "comments": ["product_id", "rating", "comment"]
  },
  "required_metric_columns": [
    "gmv",
    "ctr",
    "cvr",
    "refund_rate"
  ],
  "example_upload_files": [
    "examples/upload_samples/product.csv",
    "examples/upload_samples/sales.csv",
    "examples/upload_samples/comments.csv"
  ],
  "prompt_templates": [
    {
      "file_name": "sales_analysis_prompt.txt",
      "required_placeholders": ["{data_text}"]
    },
    {
      "file_name": "user_insight_prompt.txt",
      "required_placeholders": ["{comments_text}"]
    },
    {
      "file_name": "content_strategy_prompt.txt",
      "required_placeholders": ["{product_text}", "{comment_text}"]
    },
    {
      "file_name": "compliance_prompt.txt",
      "required_placeholders": ["{content}"]
    }
  ],
  "supervisor_required_keys": [
    "sales_analysis",
    "user_insight",
    "content_strategy",
    "compliance_review",
    "traces"
  ],
